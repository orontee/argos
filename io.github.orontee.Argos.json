{
    "app-id" : "io.github.orontee.Argos",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "49",
    "sdk" : "org.gnome.Sdk",
    "command" : "argos",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--talk-name=org.freedesktop.Notifications"
    ],
    "modules" : [
        "pypi-dependencies.yaml",
	{
            "name" : "argos",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources": [{
                "type": "dir",
                "path": "."
            }]
        }
    ]
}
