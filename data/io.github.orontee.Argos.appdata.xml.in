<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
  <id>io.github.orontee.Argos.desktop</id>

  <name>Argos</name>
  <summary>Mopidy music client</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>Argos aims to be compatible with both desktop computers running
    the Gnome environment and single-board devices with a small
    touchscreen.</p>
  </description>

  <launchable type="desktop-id">io.github.orontee.Argos.desktop</launchable>
  <screenshots>
    <screenshot type="default" xml:lang="fr">
      <image type="source">https://github.com/orontee/argos/raw/main/docs/screenshot.png</image>
      <caption>Tracklist view</caption>
    </screenshot>
    <screenshot xml:lang="fr">
      <image type="source">https://github.com/orontee/argos/raw/main/docs/screenshot-library-view.png</image>
      <caption>Library view</caption>
    </screenshot>
    <screenshot xml:lang="fr">
      <image type="source">https://github.com/orontee/argos/raw/main/docs/screenshot-playlists-view.png</image>
      <caption>Playlists view</caption>
    </screenshot>
    <screenshot xml:lang="fr">
      <image type="source">https://github.com/orontee/argos/raw/main/docs/screenshot-album-details-view.png</image>
      <caption>Album details view</caption>
    </screenshot>
  </screenshots>

  <releases>
